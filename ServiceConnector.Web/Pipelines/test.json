[
  {
    "RequestId": "test-request",
    "Request": {
      "type": "object",
      "properties": {
        "header": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ]
    },
    "Pipeline": [
      {
        "Type": "HttpRequest",
        "Id": "TestGet",
        "Method": "GET",
        "Url": "http://localhost:5158/api/TestGet",
        "Params": {
          "request": "$request.name"
        },
        "Response": {
          "type": "object",
          "properties": {
            "Header": {
              "type": "string"
            },
            "response": {
              "type": "string"
            }
          }
        }
      },
      {
        "Type": "HttpRequest",
        "Id": "TestPost",
        "Method": "POST",
        "Url": "http://localhost:5158/api/TestPost",
        "Headers": {
          "test-header": "$headers.User-Agent"
        },
        "Data": {
          "request": "$request.name"
        },
        "Response": {
          "type": "object",
          "properties": {
            "Header": {
              "type": "string"
            },
            "response": {
              "type": "string"
            }
          }
        }
      },
      {
        "Type": "Mapping",
        "Id": "result",
        "List": "$array",
        "Map": {
          "Title": "$item.Title",
          "TitleType": "{{$item.Title}}--{{$item.Type}}"
        }
      },
      {
        "Type": "Object",
        "Id": "array",
        "Data": [
          {
            "Title": "Настройки",
            "Type": "link",
            "Icon": "settings",
            "Target": "_blank"
          },
          {
            "Title": "Выход",
            "Type": "button",
            "Icon": "logout",
            "Action": "logout"
          }
        ]
      },
      {
        "Type": "Object",
        "Id": "variable",
        "Data": {
          "TestGet": "$TestGet",
          "TestPost": "$TestPost"
        }
      }
    ]
  }
]