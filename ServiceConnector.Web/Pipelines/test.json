[
  {
    "RequestId": "test-request",
    "Request": {
      "type": "object",
      "properties": {
        "header": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "array": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Title": {
                "type": "string"
              },
              "TitleType": {
                "type": "string"
              },
              "Type": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "name"
      ]
    },
    "Pipeline": [
      {
        "Type": "HttpRequest",
        "Id": "TestGet",
        "Method": "GET",
        "Url": "http://localhost:5158/api/TestGet",
        "Params": {
          "request": "$request.name"
        },
        "Response": {
          "type": "object",
          "properties": {
            "Header": {
              "type": "string"
            },
            "response": {
              "type": "string"
            }
          }
        }
      },
      {
        "Type": "HttpRequest",
        "Id": "TestPost",
        "Method": "POST",
        "Url": "http://localhost:5158/api/TestPost",
        "Headers": {
          "test-header": "$headers.User-Agent"
        },
        "Data": {
          "request": "$request.name"
        },
        "Response": {
          "type": "object",
          "properties": {
            "Header": {
              "type": "string"
            },
            "response": {
              "type": "string"
            }
          }
        }
      },
      {
        "Type": "Object",
        "Id": "array",
        "Data": [
          {
            "Num": 1,
            "Title": "Test",
            "TestGet": "$TestGet",
            "TestPost": "$TestPost"
          },
          {
            "Title": "Настройки",
            "Type": "link",
            "Icon": "settings",
            "Target": "_blank"
          },
          {
            "Title": "Выход",
            "Type": "button",
            "Icon": "logout",
            "Action": "logout"
          }
        ]
      },
      {
        "Type": "Mapping",
        "Id": "result",
        "Lists": [
          "$array",
          "$request.array"
        ],
        "Map": {
          "Num": "$item.Num",
          "Title": "$item.Title",
          "Title0": "$item0.Title",
          "Title1": "$item1.Title",
          "TitleType": "{{$item.Title}}--{{$item.Type}}"
        }
      },
      {
        "Type": "Object",
        "Id": "variable",
        "Data": {
          "array": "$array",
          "result": "$result"
        }
      }
    ]
  }
]