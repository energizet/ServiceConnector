[
  {
    "RequestId": "test-request",
    "Request": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "array": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "Title": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "name"
      ]
    },
    "Pipeline": [
      {
        "Type": "HttpRequest",
        "Id": "TestGet",
        "Method": "GET",
        "Url": "http://localhost:5158/api/TestGet",
        "Params": {
          "request": "$request.name"
        },
        "Response": {
          "type": "object",
          "properties": {
            "Header": {
              "type": "string"
            },
            "response": {
              "type": "string"
            }
          }
        }
      },
      {
        "Type": "HttpRequest",
        "Id": "TestPost",
        "Method": "POST",
        "Url": "http://localhost:5158/api/TestPost",
        "Headers": {
          "test-header": "$headers.User-Agent"
        },
        "Data": {
          "request": "$request.name"
        },
        "Response": {
          "type": "object",
          "properties": {
            "Header": {
              "type": "string"
            },
            "response": {
              "type": "string"
            }
          }
        }
      },
      {
        "Type": "Object",
        "Id": "array",
        "Data": [
          {
            "Title": "Test"
          },
          {
            "Title": "Настройки"
          },
          {
            "Title": "Выход"
          }
        ]
      },
      {
        "Type": "Mapping",
        "Id": "mapping",
        "Lists": [
          "$array",
          "$request.array"
        ],
        "Map": {
          "Title": "$item.Title",
          "StaticTitle": "$item0.Title",
          "RequestTitle": "$item1.Title",
          "Name": "$TestGet.response"
        }
      },
      {
        "Type": "Object",
        "Id": "variable",
        "Data": {
          "array": "$array",
          "mapping": "$mapping",
          "TestPost": "$TestPost"
        }
      }
    ]
  }
]